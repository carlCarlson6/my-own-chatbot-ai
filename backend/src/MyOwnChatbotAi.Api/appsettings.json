{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ollama": {
    "BaseUrl": "http://127.0.0.1:11434",
    "DefaultModel": "mistral",
    "TimeoutSeconds": 120
  },
  "ConversationPersistence": {
    "DatabasePath": "App_Data/conversations.sqlite"
  }
}
